// ==========================================
// DISCORD OAUTH2 CONFIGURATION
// ==========================================
// To enable Discord login:
// 1. Go to https://discord.com/developers/applications
// 2. Create a New Application, then go to OAuth2 > General
// 3. Add Redirect URI: http://localhost:3000/index.html (for local dev)
//    and https://mmesports.in/index.html (for production)
// 4. Copy your Client ID and paste it below
const DISCORD_CLIENT_ID = '1477227771334889574';
const DISCORD_REDIRECT_URI = window.location.origin + '/index.html';
const DISCORD_SCOPES = 'identify email';

// Initiate Discord OAuth2 Login (Implicit Flow - no backend needed)
function loginWithDiscord() {
    if (DISCORD_CLIENT_ID === 'YOUR_DISCORD_CLIENT_ID') {
        alert("Discord login is not configured yet. Please contact the admin or use Email/Password login.");
        return;
    }
    const state = Math.random().toString(36).substring(2);
    sessionStorage.setItem('discord_oauth_state', state);

    const discordAuthUrl = `https://discord.com/api/oauth2/authorize` +
        `?client_id=${DISCORD_CLIENT_ID}` +
        `&redirect_uri=${encodeURIComponent(DISCORD_REDIRECT_URI)}` +
        `&response_type=token` +
        `&scope=${encodeURIComponent(DISCORD_SCOPES)}` +
        `&state=${state}`;

    window.location.href = discordAuthUrl;
}

// Handle Discord OAuth2 callback (called on page load if hash fragment present)
async function handleDiscordCallback() {
    const hash = window.location.hash;
    if (!hash || !hash.includes('access_token')) return;

    const params = new URLSearchParams(hash.substring(1));
    const accessToken = params.get('access_token');
    const tokenType = params.get('token_type');
    const state = params.get('state');
    const savedState = sessionStorage.getItem('discord_oauth_state');

    // Clear hash from URL
    history.replaceState(null, null, window.location.pathname);

    if (!accessToken) return;
    if (state && savedState && state !== savedState) {
        console.error("Discord OAuth state mismatch. Possible CSRF attack.");
        return;
    }
    sessionStorage.removeItem('discord_oauth_state');

    // Show loading state
    showDiscordLoading(true);

    try {
        // Fetch Discord user info
        const discordRes = await fetch('https://discord.com/api/users/@me', {
            headers: { Authorization: `${tokenType} ${accessToken}` }
        });

        if (!discordRes.ok) throw new Error("Failed to fetch Discord user data.");
        const discordUser = await discordRes.json();

        const discordEmail = discordUser.email || `discord_${discordUser.id}@mmesports.app`;
        const discordPassword = `discord_${discordUser.id}_mmesports_secure`;
        const discordName = discordUser.global_name || discordUser.username;

        // Try to sign in first; if no account, create one
        let firebaseUser;
        try {
            const loginResult = await auth.signInWithEmailAndPassword(discordEmail, discordPassword);
            firebaseUser = loginResult.user;
        } catch (loginErr) {
            if (loginErr.code === 'auth/user-not-found' || loginErr.code === 'auth/invalid-credential' || loginErr.code === 'auth/invalid-email') {
                // Create new account
                const createResult = await auth.createUserWithEmailAndPassword(discordEmail, discordPassword);
                firebaseUser = createResult.user;

                await firebaseUser.updateProfile({ displayName: discordName });

                // Save to Firestore
                await db.collection('users').doc(firebaseUser.uid).set({
                    name: discordName,
                    ign: discordUser.username,
                    bgmi_id: '',
                    discord: discordUser.username + '#' + (discordUser.discriminator || '0'),
                    phone: '',
                    email: discordEmail,
                    discord_id: discordUser.id,
                    createdAt: firebase.firestore.FieldValue.serverTimestamp()
                });
            } else {
                throw loginErr;
            }
        }

        closeAuthModal();
        updateUIForUser(firebaseUser);
        console.log("Discord login successful:", firebaseUser.displayName);

    } catch (error) {
        console.error("Discord login error:", error);
        alert("Discord login failed: " + error.message);
    } finally {
        showDiscordLoading(false);
    }
}

function showDiscordLoading(loading) {
    const discordBtns = document.querySelectorAll('.discord-login-btn');
    discordBtns.forEach(btn => {
        btn.disabled = loading;
        btn.innerHTML = loading
            ? '<i class="fas fa-spinner fa-spin"></i> Connecting...'
            : '<i class="fab fa-discord"></i> Login with Discord';
    });
}

