function openAuthModal() {
    const authModal = document.getElementById('authModal');
    if (authModal) {
        authModal.classList.add('active');
        document.body.style.overflow = 'hidden';
    }
}

function closeAuthModal() {
    const authModal = document.getElementById('authModal');
    if (authModal) {
        authModal.classList.remove('active');
        document.body.style.overflow = '';
    }
}

// Close modals when clicking outside
window.onclick = function (event) {
    const authModal = document.getElementById('authModal');
    if (authModal && event.target === authModal) {
        closeAuthModal();
    }
    const profileModal = document.getElementById('profileModal');
    if (profileModal && event.target === profileModal) {
        closeProfileModal();
    }
};

// ==========================================
// PROFILE MODAL LOGIC
// ==========================================

async function openProfileModal() {
    const profileModal = document.getElementById('profileModal');
    if (profileModal) {
        profileModal.classList.add('active');
        document.body.style.overflow = 'hidden';

        document.getElementById('profileViewMode').style.display = 'block';
        document.getElementById('profileEditMode').style.display = 'none';

        await fetchAndDisplayUserData();
    }
}

function closeProfileModal() {
    const profileModal = document.getElementById('profileModal');
    if (profileModal) {
        profileModal.classList.remove('active');
        document.body.style.overflow = '';
    }
}

function toggleProfileEditMode() {
    const viewMode = document.getElementById('profileViewMode');
    const editMode = document.getElementById('profileEditMode');

    if (viewMode.style.display === 'none') {
        viewMode.style.display = 'block';
        editMode.style.display = 'none';
    } else {
        viewMode.style.display = 'none';
        editMode.style.display = 'block';

        document.getElementById('editProfileName').value = document.getElementById('viewProfileName').innerText;
        document.getElementById('editProfileIGN').value = document.getElementById('viewProfileIGN').innerText;
        document.getElementById('editProfileBGMI').value = document.getElementById('viewProfileBGMI').innerText;
        document.getElementById('editProfileDiscord').value = document.getElementById('viewProfileDiscord').innerText;
        document.getElementById('editProfilePhone').value = document.getElementById('viewProfilePhone').innerText;
    }
}

async function fetchAndDisplayUserData() {
    const user = auth.currentUser;
    if (!user) return;

    document.getElementById('profileDisplayName').innerText = user.displayName || "Player Profile";
    document.getElementById('viewProfileEmail').innerText = user.email || "N/A";

    try {
        const docRef = db.collection('users').doc(user.uid);
        const docSnap = await docRef.get();

        if (docSnap.exists) {
            const data = docSnap.data();
            document.getElementById('viewProfileName').innerText = data.name || "N/A";
            document.getElementById('viewProfileIGN').innerText = data.ign || "N/A";
            document.getElementById('viewProfileBGMI').innerText = data.bgmi_id || "N/A";
            document.getElementById('viewProfileDiscord').innerText = data.discord || "N/A";
            document.getElementById('viewProfilePhone').innerText = data.phone || "N/A";
        } else {
            ['viewProfileName', 'viewProfileIGN', 'viewProfileBGMI', 'viewProfileDiscord', 'viewProfilePhone'].forEach(id => {
                document.getElementById(id).innerText = "N/A";
            });
        }
    } catch (error) {
        console.error("Error fetching user data:", error);
    }
}

async function saveProfileChanges() {
    const user = auth.currentUser;
    if (!user) return;

    const saveBtn = document.querySelector('.profile-save-btn');
    const originalText = saveBtn.innerText;
    saveBtn.innerText = "Saving...";
    saveBtn.disabled = true;

    try {
        const newName = document.getElementById('editProfileName').value;
        const newIgn = document.getElementById('editProfileIGN').value;
        const newBgmi = document.getElementById('editProfileBGMI').value;
        const newDiscord = document.getElementById('editProfileDiscord').value;
        const newPhone = document.getElementById('editProfilePhone').value;

        await db.collection('users').doc(user.uid).update({
            name: newName,
            ign: newIgn,
            bgmi_id: newBgmi,
            discord: newDiscord,
            phone: newPhone,
            updatedAt: firebase.firestore.FieldValue.serverTimestamp()
        });

        if (user.displayName !== newName) {
            await user.updateProfile({ displayName: newName });
        }

        document.getElementById('viewProfileName').innerText = newName;
        document.getElementById('viewProfileIGN').innerText = newIgn;
        document.getElementById('viewProfileBGMI').innerText = newBgmi;
        document.getElementById('viewProfileDiscord').innerText = newDiscord;
        document.getElementById('viewProfilePhone').innerText = newPhone;
        document.getElementById('profileDisplayName').innerText = newName;

        toggleProfileEditMode();

    } catch (error) {
        console.error("Error updating profile:", error);
        alert("Failed to update profile. Please try again.");
    } finally {
        saveBtn.innerText = originalText;
        saveBtn.disabled = false;
    }
}

// ==========================================
// AUTH STATE OBSERVER
// ==========================================

auth.onAuthStateChanged((user) => {
    if (user) {
        updateUIForUser(user);
    } else {
        updateUIForLoggedOut();
        // Handle Discord OAuth callback on page load
        handleDiscordCallback();
    }
});

// ==========================================
// AUTH MODE TOGGLE — global, called via onclick in HTML
// ==========================================

function switchAuthMode(e) {
    if (e) e.preventDefault();

    var link = document.getElementById('toggleAuthMode');
    if (!link) return;

    var container = link.closest('.auth-modal-content');
    if (!container) return;

    var currentMode = link.getAttribute('data-current-mode') || 'login';
    var authTitle = container.querySelector('h2');
    var authSub = container.querySelector('p');
    var submitBtn = container.querySelector('.auth-submit-btn');
    var signupFields = container.querySelector('.signup-fields');
    var authForm = container.querySelector('.auth-form');

    if (currentMode === 'login') {
        if (authTitle) authTitle.textContent = 'Create Account';
        if (authSub) authSub.textContent = 'Join the MM Esports community';
        if (submitBtn) submitBtn.textContent = 'Sign Up';
        if (signupFields) signupFields.style.display = 'block';
        link.textContent = 'Login here';
        link.setAttribute('data-current-mode', 'signup');
        if (authForm) authForm.setAttribute('data-mode', 'signup');
    } else {
        if (authTitle) authTitle.textContent = 'Welcome Back';
        if (authSub) authSub.textContent = 'Sign in to MM Esports';
        if (submitBtn) submitBtn.textContent = 'Login';
        if (signupFields) signupFields.style.display = 'none';
        link.textContent = 'Sign up';
        link.setAttribute('data-current-mode', 'login');
        if (authForm) authForm.setAttribute('data-mode', 'login');
    }
}

// ==========================================
// DOM EVENT LISTENERS
// ==========================================

document.addEventListener('DOMContentLoaded', function () {

    // Discord Button click handlers
    document.querySelectorAll('.discord-login-btn').forEach(function (btn) {
        btn.addEventListener('click', loginWithDiscord);
    });

    // Form Submit Handler
    document.querySelectorAll('.auth-form').forEach(function (form) {
        form.setAttribute('data-mode', 'login');

        form.addEventListener('submit', function (e) {
            e.preventDefault();

            var mode = form.getAttribute('data-mode');
            var emailInput = form.querySelector('input[type="email"]');
            var passwordInput = form.querySelector('input[type="password"]');

            if (!emailInput || !passwordInput) {
                alert('Form error: email or password field not found.');
                return;
            }

            if (mode === 'signup') {
                var name = (form.querySelector('#name') || { value: '' }).value.trim();
                var ign = (form.querySelector('#ign') || { value: '' }).value.trim();
                var bgmi_id = (form.querySelector('#bgmi_id') || { value: '' }).value.trim();
                var discord = (form.querySelector('#discord') || { value: '' }).value.trim();
                var phone = (form.querySelector('#phone') || { value: '' }).value.trim();

                if (!name || !ign || !bgmi_id) {
                    alert('Please fill in all required fields: Full Name, In-Game Name, and BGMI Character ID.');
                    return;
                }

                signUpWithEmail(name, ign, bgmi_id, discord, phone, emailInput.value, passwordInput.value);
            } else {
                loginWithEmail(emailInput.value, passwordInput.value);
            }
        });
    });
});

